<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  CarPlay entitlement options:
	  com.apple.developer.carplay-parking: parking apps and point-of-interest flows. Keep this for the example POI demo.
	  com.apple.developer.carplay-maps: maps and navigation apps.
	  com.apple.developer.carplay-quick-ordering: quick food or item ordering apps.
	  com.apple.developer.carplay-charging: EV charging apps.
	  com.apple.developer.carplay-fueling: fuel station apps.
	  com.apple.developer.carplay-driving-task: driving task apps.
	  com.apple.developer.carplay-communication: calling or messaging apps.
	  com.apple.developer.carplay-audio: audio playback apps.
	  Replace the key below with the entitlement Apple approved for your app category.
	-->
	<key>com.apple.developer.carplay-parking</key>
	<true/>
</dict>
</plist>
